# Template for the local .env file. Copy to .env (gitignored) and fill in.
# Real values for prod builds live in Infisical (otaku-internal / env=prod /
# path=/myrp-build) and are injected at build time via:
#   infisical run --projectId e56e0da5-6460-4bab-bdd6-2fd12ac5447b --env prod \
#       --path /myrp-build --recursive -- <build command>
#
# (See package.json `build:prod` / `build:win` / `build:unpack:nosign`.)

# ---- Dev runtime (used by `npm run dev`) ----------------------------------

# Vercel AI Gateway key for local generation — free monthly credits, get one at
# https://vercel.com/ai-gateway. ALL inference goes through the Vercel AI SDK
# gateway, which routes to any provider (anthropic/*, openai/*, google/*, …).
# There is no bare-provider fallback: without a gateway key (and without a
# signed-in proxy session), generation fails fast.
VERCEL_GATEWAY_KEY=YOUR_KEY_HERE

# OpenAI key — voice input transcription only (dev/owner; see src/main/ipc/voice.ts).
# RAG + semantic search now embed LOCALLY via fastembed (no key needed). Blank = no voice.
OPENAI_API_KEY=YOUR_KEY_HERE

# Local Supabase stack (`supabase start`). Default port mapping is 5532x.
VITE_SUPABASE_URL=http://127.0.0.1:55321
VITE_SUPABASE_ANON_KEY=sb_publishable_YOUR_LOCAL_ANON_KEY

# Discord OAuth provider for native Supabase Auth. The Supabase
# CLI reads these from this .env at `supabase start`/`db reset` to fill
# config.toml [auth.external.discord]. Create a Discord app at
# https://discord.com/developers/applications and add the OAuth2 redirect URI:
#   http://127.0.0.1:55321/auth/v1/callback   (local stack auth callback)
SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID_HERE
SUPABASE_AUTH_EXTERNAL_DISCORD_SECRET=YOUR_DISCORD_CLIENT_SECRET_HERE

# GitHub OAuth — NOT a sign-in provider; used only to link a GitHub identity onto
# the signed-in user so server folders can be backed up to GitHub. Create a
# GitHub OAuth App at https://github.com/settings/developers
# with Authorization callback URL:
#   http://127.0.0.1:55321/auth/v1/callback   (local stack auth callback)
# Read by the Supabase CLI at `supabase start` to fill config.toml
# [auth.external.github]. Mirror in the prod dashboard (Authentication →
# Providers → GitHub) and enable "Manual linking".
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=YOUR_GITHUB_OAUTH_CLIENT_ID_HERE
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=YOUR_GITHUB_OAUTH_CLIENT_SECRET_HERE

# Local RAG / Mastra memory Postgres (same Supabase stack).
RAG_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:55322/postgres

# Dev inference proxy (Supabase edge fn). Empty = use the gateway key above.
PROXY_BASE_URL=

# GTA map tiles base URL (the in-app coordinate/map tool). Leave BLANK to use
# tiles bundled locally under src/renderer/public/assets/maps. The open-source
# client ships WITHOUT those tiles (they are Rockstar's imagery), so to enable
# the map either point this at a tile server that serves {z}/{x}/{y} tiles, or
# drop your own tiles into that folder. Owner/local builds keep the default.
VITE_MAP_TILE_BASE_URL=

# ---- Dev opt-in for the bypass branch ------------------------------------
# Set to "1" to skip Supabase sign-in + Stripe in `npm run dev` (lets you iterate
# on the agent without going through auth). Has ZERO effect in packaged builds
# — the Vite build inlines this as the literal `false` and the bypass branch
# is DCE'd out of out/main/index.js (hardening). Comment out
# to exercise the prod auth path against your local Supabase stack.
FIVEM_STUDIO_DEV=1
