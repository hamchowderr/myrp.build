{
  "name": "myrp-build",
  "version": "0.1.0",
  "description": "AI-powered resource generator for FiveM server developers",
  "main": "./out/main/index.js",
  "author": "Otaku Solutions",
  "homepage": "https://myrp.build",
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write --unsafe .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "dev:secrets": "infisical run --projectId e56e0da5-6460-4bab-bdd6-2fd12ac5447b --env dev --recursive --silent -- electron-vite dev",
    "dev:prod": "infisical run --projectId e56e0da5-6460-4bab-bdd6-2fd12ac5447b --env prod --path /myrp-build --recursive --silent -- electron-vite dev",
    "dev:auth": "node scripts/dev-auth.mjs",
    "db:drift-check": "node scripts/db-drift-check.mjs",
    "ox:currency": "node scripts/check-ox-currency.mjs",
    "build": "npm run typecheck && electron-vite build --mode development",
    "build:prod": "npm run typecheck && infisical run --projectId e56e0da5-6460-4bab-bdd6-2fd12ac5447b --env prod --path /myrp-build --recursive --silent -- electron-vite build --mode production",
    "postinstall": "electron-builder install-app-deps",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:unpack": "npm run clean && npm run build:prod && electron-builder --dir",
    "build:unpack:nosign": "npm run clean && npm run build:prod && electron-builder --dir --config electron-builder.nosign.yml",
    "build:unpack:e2e": "npm run clean && npm run build:prod && electron-builder --dir --config electron-builder.e2e.yml",
    "build:win": "npm run clean && npm run build:prod && electron-builder --win",
    "build:mac": "npm run clean && npm run build:prod && electron-builder --mac",
    "build:linux": "npm run clean && npm run build:prod && electron-builder --linux",
    "fallow": "fallow",
    "fallow:audit": "fallow audit",
    "fallow:fix": "fallow fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "studio": "mastra dev --dir studio --env .env"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.12",
    "@ai-sdk/openai": "^4.0.11",
    "@ai-sdk/react": "^4.0.23",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/sora": "^5.2.8",
    "@mastra/ai-sdk": "^1.6.1",
    "@mastra/core": "^1.50.1",
    "@mastra/fastembed": "^1.2.0",
    "@mastra/memory": "^1.22.2",
    "@mastra/pg": "^1.15.1",
    "@msgpack/msgpack": "^3.1.3",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/code": "^1.1.1",
    "@supabase/supabase-js": "^2.106.1",
    "@types/pg": "^8.20.0",
    "ai": "^7.0.22",
    "anser": "^2.3.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.3.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "koffi": "^2.15.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "mysql2": "^3.22.4",
    "nanoid": "^5.1.11",
    "pg": "^8.21.0",
    "radix-ui": "^1.4.3",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "react-resizable-panels": "^3.0.6",
    "shiki": "^4.1.0",
    "sonner": "^1.7.4",
    "streamdown": "^2.5.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@copilotkit/aimock": "^1.27.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@mastra/editor": "^0.13.6",
    "@mastra/mcp": "^1.13.1",
    "@mastra/observability": "^1.16.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.14.0",
    "electron-vite": "^5.0.0",
    "fallow": "^2.84.0",
    "mastra": "^1.16.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.7"
  }
}
