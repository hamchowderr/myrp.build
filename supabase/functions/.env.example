# Edge Function secrets. Local: copy to supabase/functions/.env (gitignored) for
# `supabase functions serve`. Prod: `supabase secrets set KEY=... ` per key.
# (SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are injected automatically.)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_KEY_HERE
STRIPE_PRO_PRICE_ID=price_YOUR_PRO_PRICE_HERE
STRIPE_SUCCESS_URL=https://myrp.build/billing/success
STRIPE_CANCEL_URL=https://myrp.build/billing/cancel
STRIPE_RETURN_URL=https://myrp.build/billing

# Auth: create-checkout/create-portal/fivem-inference-proxy verify the user's
# Supabase session JWT in-function via SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY
# (both injected automatically). No extra auth secrets needed.
