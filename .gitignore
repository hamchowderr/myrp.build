.claude/settings.json

# --- public repo additions (pre-publish) ---
# GTA map tiles are not bundled (Rockstar imagery). Drop your own here, or set
# VITE_MAP_TILE_BASE_URL. The README stays tracked; everything else is ignored.
src/renderer/public/assets/maps/*
!src/renderer/public/assets/maps/README.md
# Eval harness lives in a separate private repo.
tests/eval/

# --- FiveM server secrets must NEVER land in THIS repo ---
# The legacy private repo (myrp-build) was contaminated when a server.cfg
# carrying sv_licenseKey / rcon_password / mysql_connection_string /
# steam_webApiKey was committed into git history — the reason myrp.build is a
# fresh clean-history repo. This app operates on an EXTERNAL server folder, so
# a server.cfg / secrets cfg has no place here; block it defensively.
# (Unrelated to server-backup.ts, which manages a SEPARATE .gitignore inside
# the USER's server repo, where server.cfg IS versioned with secrets
# externalized to the ignored myrp-secrets.cfg.)
server.cfg
myrp-secrets.cfg
*secrets*.cfg
